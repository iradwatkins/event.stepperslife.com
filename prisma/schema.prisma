generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String            @id @default(uuid())
  email              String            @unique
  emailVerified      DateTime?
  passwordHash       String?
  firstName          String            @default("")
  lastName           String            @default("")
  displayName        String?
  phone              String?
  dateOfBirth        DateTime?
  profileImage       String?
  bio                String?
  role               UserRole          @default(ATTENDEE)
  status             UserStatus        @default(ACTIVE)
  isVerified         Boolean           @default(false)
  twoFactorEnabled   Boolean           @default(false)
  timezone           String            @default("America/New_York")
  language           String            @default("en")
  marketingOptIn     Boolean           @default(false)
  squareCustomerId   String?           @unique
  metadata           Json?             @default("{}")
  lastLoginAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?
  accounts           Account[]
  affiliate          Affiliate?
  billingAccount     BillingAccount?
  favorites          EventFavorite[]
  eventsCreated      Event[]           @relation("EventOrganizer")
  following          Follow[]          @relation("Follower")
  followers          Follow[]          @relation("Following")
  orders             Order[]
  organizerProfile   OrganizerProfile?
  reviews            Review[]
  sessions           Session[]
  teamMemberships    TeamMember[]
  transfersInitiated TicketTransfer[]  @relation("TransferFrom")
  transfersReceived  TicketTransfer[]  @relation("TransferTo")
  tickets            Ticket[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([squareCustomerId])
  @@map("users")
}

model OrganizerProfile {
  id                    String            @id @default(uuid())
  userId                String            @unique
  businessName          String
  businessType          BusinessType      @default(INDIVIDUAL)
  taxId                 String?
  website               String?
  socialMedia           Json?             @default("{}")
  squareLocationId      String?
  squareBusinessId      String?
  squareApplication     String?
  isVerified            Boolean           @default(false)
  verifiedAt            DateTime?
  verificationLevel     VerificationLevel @default(BASIC)
  autoPayoutEnabled     Boolean           @default(true)
  defaultPayoutSchedule PayoutSchedule    @default(DAILY)
  totalEvents           Int               @default(0)
  totalRevenue          Decimal           @default(0) @db.Decimal(12, 2)
  averageRating         Float?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  team                  TeamMember[]
  venues                Venue[]

  @@map("organizer_profiles")
}

model TeamMember {
  id          String           @id @default(uuid())
  organizerId String
  userId      String
  role        TeamRole         @default(STAFF)
  permissions String[]         @default([])
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  organizer   OrganizerProfile @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizerId, userId])
  @@map("team_members")
}

model Venue {
  id            String           @id @default(uuid())
  organizerId   String
  name          String
  slug          String           @unique
  description   String?
  address       String
  city          String
  state         String
  zipCode       String
  country       String           @default("US")
  latitude      Float?
  longitude     Float?
  timezone      String           @default("America/New_York")
  maxCapacity   Int
  hasSeating    Boolean          @default(false)
  hasParking    Boolean          @default(false)
  isAccessible  Boolean          @default(true)
  amenities     String[]         @default([])
  phone         String?
  email         String?
  website       String?
  coverImage    String?
  gallery       String[]         @default([])
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  events        Event[]
  seatingCharts SeatingChart[]
  organizer     OrganizerProfile @relation(fields: [organizerId], references: [id])

  @@index([organizerId])
  @@index([city, state])
  @@map("venues")
}

model SeatingChart {
  id          String   @id @default(uuid())
  venueId     String
  name        String
  description String?
  isDefault   Boolean  @default(false)
  layout      Json
  sections    Json
  totalSeats  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  events      Event[]
  venue       Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  seats       Seat[]

  @@index([venueId])
  @@map("seating_charts")
}

model Seat {
  id             String       @id @default(uuid())
  seatingChartId String
  section        String
  row            String
  number         String
  seatType       SeatType     @default(STANDARD)
  isAccessible   Boolean      @default(false)
  x              Float?
  y              Float?
  seatingChart   SeatingChart @relation(fields: [seatingChartId], references: [id], onDelete: Cascade)
  tickets        Ticket[]

  @@unique([seatingChartId, section, row, number])
  @@index([seatingChartId])
  @@map("seats")
}

model Event {
  id                   String                 @id @default(uuid())
  organizerId          String
  venueId              String?
  seatingChartId       String?
  name                 String
  slug                 String                 @unique
  description          String?
  shortDescription     String?
  startDate            DateTime
  endDate              DateTime
  timezone             String                 @default("America/New_York")
  eventType            EventType              @default(SETS)
  isVirtual            Boolean                @default(false)
  virtualUrl           String?
  maxCapacity          Int?
  salesStartDate       DateTime?
  salesEndDate         DateTime?
  status               EventStatus            @default(DRAFT)
  visibility           EventVisibility        @default(PUBLIC)
  isFeatured           Boolean                @default(false)
  coverImage           String?
  gallery              String[]               @default([])
  metaTitle            String?
  metaDescription      String?
  tags                 String[]               @default([])
  squareCatalogId      String?                @unique
  squareLocationId     String?
  settings             Json                   @default("{}")
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  publishedAt          DateTime?
  deletedAt            DateTime?
  EventToEventCategory EventToEventCategory[]
  affiliateLinks       AffiliateLink[]
  affiliateSales       AffiliateSale[]
  discounts            Discount[]
  favorites            EventFavorite[]
  sessions             EventSession[]
  organizer            User                   @relation("EventOrganizer", fields: [organizerId], references: [id])
  seatingChart         SeatingChart?          @relation(fields: [seatingChartId], references: [id])
  venue                Venue?                 @relation(fields: [venueId], references: [id])
  orders               Order[]
  reviews              Review[]
  taxExemption         TaxExemption?
  ticketTypes          TicketType[]
  tickets              Ticket[]
  waitlists            Waitlist[]

  @@index([organizerId])
  @@index([slug])
  @@index([startDate])
  @@index([status])
  @@index([squareCatalogId])
  @@map("events")
}

model EventCategory {
  id                   String                 @id @default(uuid())
  name                 String                 @unique
  slug                 String                 @unique
  description          String?
  color                String?
  icon                 String?
  sortOrder            Int                    @default(0)
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  EventToEventCategory EventToEventCategory[]

  @@map("event_categories")
}

model EventSession {
  id          String   @id @default(uuid())
  eventId     String
  name        String
  description String?
  startTime   DateTime
  endTime     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_sessions")
}

model TicketType {
  id                String    @id @default(uuid())
  eventId           String
  name              String
  description       String?
  price             Decimal   @db.Decimal(10, 2)
  currency          String    @default("USD")
  quantity          Int
  sold              Int       @default(0)
  reserved          Int       @default(0)
  minPerOrder       Int       @default(1)
  maxPerOrder       Int       @default(10)
  salesStartDate    DateTime?
  salesEndDate      DateTime?
  squareItemId      String?   @unique
  squareVariationId String?   @unique
  requiresSeat      Boolean   @default(false)
  allowedSections   String[]  @default([])
  rules             Json      @default("{}")
  metadata          Json?
  isActive          Boolean   @default(true)
  sortOrder         Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  event             Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tickets           Ticket[]

  @@index([eventId])
  @@index([squareItemId])
  @@map("ticket_types")
}

model Order {
  id                   String                @id @default(uuid())
  orderNumber          String                @unique
  eventId              String
  userId               String?
  email                String
  firstName            String
  lastName             String
  phone                String?
  subtotal             Decimal               @db.Decimal(10, 2)
  fees                 Decimal               @default(0) @db.Decimal(10, 2)
  taxes                Decimal               @default(0) @db.Decimal(10, 2)
  total                Decimal               @db.Decimal(10, 2)
  currency             String                @default("USD")
  status               OrderStatus           @default(PENDING)
  squareOrderId        String?               @unique
  squarePaymentId      String?               @unique
  squareReceiptUrl     String?
  squareReceiptNumber  String?
  paymentMethod        String?
  paymentStatus        PaymentStatus         @default(PENDING)
  browserInfo          Json?
  ipAddress            String?
  source               String?               @default("web")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  completedAt          DateTime?
  taxBreakdown         Json?
  taxExempt            Boolean               @default(false)
  taxExemptionId       String?
  taxRate              Decimal?              @db.Decimal(6, 4)
  affiliateSale        AffiliateSale?
  discountUses         DiscountUse[]
  event                Event                 @relation(fields: [eventId], references: [id])
  user                 User?                 @relation(fields: [userId], references: [id])
  payment              Payment?
  platformTransactions PlatformTransaction[]
  refunds              Refund[]
  tickets              Ticket[]

  @@index([orderNumber])
  @@index([eventId])
  @@index([userId])
  @@index([email])
  @@index([status])
  @@map("orders")
}

model Ticket {
  id              String           @id @default(uuid())
  ticketNumber    String           @unique
  orderId         String
  ticketTypeId    String
  eventId         String
  userId          String?
  seatId          String?
  holderName      String?
  holderEmail     String?
  faceValue       Decimal          @db.Decimal(10, 2)
  fees            Decimal          @default(0) @db.Decimal(10, 2)
  status          TicketStatus     @default(VALID)
  qrCode          String           @unique
  validationCode  String           @unique
  checkedIn       Boolean          @default(false)
  checkedInAt     DateTime?
  checkedInBy     String?
  checkInMethod   CheckInMethod?
  checkInLocation String?
  transferrable   Boolean          @default(true)
  resaleable      Boolean          @default(false)
  transferredAt   DateTime?
  transferredTo   String?
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  transfers       TicketTransfer[]
  event           Event            @relation(fields: [eventId], references: [id])
  order           Order            @relation(fields: [orderId], references: [id])
  seat            Seat?            @relation(fields: [seatId], references: [id])
  ticketType      TicketType       @relation(fields: [ticketTypeId], references: [id])
  user            User?            @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([ticketTypeId])
  @@index([eventId])
  @@index([userId])
  @@index([qrCode])
  @@index([status])
  @@map("tickets")
}

model Payment {
  id               String        @id @default(uuid())
  orderId          String        @unique
  amount           Decimal       @db.Decimal(10, 2)
  currency         String        @default("USD")
  method           PaymentMethod
  squarePaymentId  String        @unique
  squareOrderId    String?
  squareLocationId String?
  squareReceiptUrl String?
  status           PaymentStatus @default(PENDING)
  cardBrand        String?
  cardLast4        String?
  cardExpMonth     Int?
  cardExpYear      Int?
  processorFee     Decimal?      @db.Decimal(10, 2)
  netAmount        Decimal?      @db.Decimal(10, 2)
  avsResult        String?
  cvvResult        String?
  riskEvaluation   Json?
  squareResponse   Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  processedAt      DateTime?
  order            Order         @relation(fields: [orderId], references: [id])
  refunds          Refund[]

  @@index([squarePaymentId])
  @@index([status])
  @@map("payments")
}

model Refund {
  id             String       @id @default(uuid())
  orderId        String
  paymentId      String?
  amount         Decimal      @db.Decimal(10, 2)
  reason         RefundReason
  reasonText     String?
  squareRefundId String?      @unique
  status         RefundStatus @default(PENDING)
  processedBy    String?
  processedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  order          Order        @relation(fields: [orderId], references: [id])
  payment        Payment?     @relation(fields: [paymentId], references: [id])

  @@index([orderId])
  @@index([squareRefundId])
  @@map("refunds")
}

model TicketTransfer {
  id          String         @id @default(uuid())
  ticketId    String
  fromUserId  String
  toEmail     String
  toUserId    String?
  status      TransferStatus @default(PENDING)
  message     String?
  oldQrCode   String
  newQrCode   String?
  initiatedAt DateTime       @default(now())
  acceptedAt  DateTime?
  declinedAt  DateTime?
  expiresAt   DateTime
  fromUser    User           @relation("TransferFrom", fields: [fromUserId], references: [id])
  ticket      Ticket         @relation(fields: [ticketId], references: [id])
  toUser      User?          @relation("TransferTo", fields: [toUserId], references: [id])

  @@index([ticketId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([status])
  @@map("ticket_transfers")
}

model Discount {
  id                    String        @id @default(uuid())
  eventId               String
  code                  String        @unique
  name                  String
  description           String?
  type                  DiscountType
  value                 Decimal       @db.Decimal(10, 2)
  isPercentage          Boolean       @default(false)
  maxUses               Int?
  maxUsesPerUser        Int?
  usedCount             Int           @default(0)
  startDate             DateTime
  endDate               DateTime
  isActive              Boolean       @default(true)
  minOrderAmount        Decimal?      @db.Decimal(10, 2)
  applicableTicketTypes String[]      @default([])
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  uses                  DiscountUse[]
  event                 Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([code])
  @@map("discounts")
}

model DiscountUse {
  id               String   @id @default(uuid())
  discountId       String
  orderId          String
  amountDiscounted Decimal  @db.Decimal(10, 2)
  createdAt        DateTime @default(now())
  discount         Discount @relation(fields: [discountId], references: [id])
  order            Order    @relation(fields: [orderId], references: [id])

  @@unique([discountId, orderId])
  @@map("discount_uses")
}

model Waitlist {
  id             String         @id @default(uuid())
  eventId        String
  email          String
  firstName      String?
  lastName       String?
  phone          String?
  ticketQuantity Int            @default(1)
  maxPrice       Decimal?       @db.Decimal(10, 2)
  status         WaitlistStatus @default(WAITING)
  notifiedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  event          Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, email])
  @@index([eventId, status])
  @@map("waitlists")
}

model Review {
  id          String    @id @default(uuid())
  eventId     String
  userId      String
  rating      Int
  title       String?
  comment     String?
  isPublic    Boolean   @default(true)
  isVerified  Boolean   @default(false)
  isModerated Boolean   @default(false)
  moderatedBy String?
  moderatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  event       Event     @relation(fields: [eventId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([eventId])
  @@map("reviews")
}

model EventFavorite {
  id        String   @id @default(uuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("event_favorites")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String
  userId     String?
  ipAddress  String?
  userAgent  String?
  oldValues  Json?
  newValues  Json?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemMetrics {
  id         String   @id @default(uuid())
  metricType String
  metricName String
  value      Float
  unit       String?
  dimensions Json?
  timestamp  DateTime @default(now())

  @@index([metricType, metricName])
  @@index([timestamp])
  @@map("system_metrics")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model BillingAccount {
  id                 String                  @id @default(uuid())
  userId             String                  @unique
  platformFeeFixed   Decimal                 @default(0.75) @db.Decimal(10, 2)
  platformFeePercent Decimal                 @default(0.00) @db.Decimal(5, 2)
  negotiatedRate     Boolean                 @default(false)
  rateEffectiveDate  DateTime?
  creditBalance      Decimal                 @default(0) @db.Decimal(10, 2)
  lifetimeCredits    Decimal                 @default(0) @db.Decimal(10, 2)
  payoutSchedule     PayoutSchedule          @default(DAILY)
  minimumPayout      Decimal                 @default(25.00) @db.Decimal(10, 2)
  pendingBalance     Decimal                 @default(0) @db.Decimal(10, 2)
  availableBalance   Decimal                 @default(0) @db.Decimal(10, 2)
  status             BillingAccountStatus    @default(ACTIVE)
  suspendedAt        DateTime?
  suspensionReason   String?
  totalRevenue       Decimal                 @default(0) @db.Decimal(12, 2)
  totalFees          Decimal                 @default(0) @db.Decimal(12, 2)
  totalPayouts       Decimal                 @default(0) @db.Decimal(12, 2)
  transactionCount   Int                     @default(0)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  user               User                    @relation(fields: [userId], references: [id])
  creditPurchases    CreditPurchase[]
  payouts            PayoutRecord[]
  transactions       PlatformTransaction[]
  subscription       WhitelabelSubscription?

  @@index([userId])
  @@index([status])
  @@map("billing_accounts")
}

model PlatformTransaction {
  id               String            @id @default(uuid())
  billingAccountId String
  type             TransactionType
  amount           Decimal           @db.Decimal(10, 2)
  currency         String            @default("USD")
  description      String?
  orderId          String?
  ticketId         String?
  eventId          String?
  squarePaymentId  String?
  creditUsed       Boolean           @default(false)
  creditAmount     Decimal?          @db.Decimal(10, 2)
  status           TransactionStatus @default(COMPLETED)
  processedAt      DateTime          @default(now())
  fiscalMonth      String
  fiscalQuarter    String
  metadata         Json?             @default("{}")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  billingAccount   BillingAccount    @relation(fields: [billingAccountId], references: [id])
  order            Order?            @relation(fields: [orderId], references: [id])

  @@index([billingAccountId])
  @@index([type])
  @@index([status])
  @@index([fiscalMonth])
  @@index([eventId])
  @@map("platform_transactions")
}

model PayoutRecord {
  id               String         @id @default(uuid())
  billingAccountId String
  payoutNumber     String         @unique
  amount           Decimal        @db.Decimal(10, 2)
  currency         String         @default("USD")
  squarePayoutId   String?        @unique
  squareBatchId    String?
  status           PayoutStatus   @default(PENDING)
  scheduledFor     DateTime
  initiatedAt      DateTime?
  completedAt      DateTime?
  failedAt         DateTime?
  failureReason    String?
  retryCount       Int            @default(0)
  maxRetries       Int            @default(3)
  periodStart      DateTime
  periodEnd        DateTime
  fiscalMonth      String
  transactionCount Int            @default(0)
  totalSales       Decimal        @default(0) @db.Decimal(12, 2)
  totalFees        Decimal        @default(0) @db.Decimal(12, 2)
  metadata         Json?          @default("{}")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  billingAccount   BillingAccount @relation(fields: [billingAccountId], references: [id])

  @@index([billingAccountId])
  @@index([status])
  @@index([scheduledFor])
  @@index([fiscalMonth])
  @@map("payout_records")
}

model CreditPurchase {
  id               String         @id @default(uuid())
  billingAccountId String
  packageAmount    Decimal        @db.Decimal(10, 2)
  purchasePrice    Decimal        @db.Decimal(10, 2)
  discountPercent  Decimal        @db.Decimal(5, 2)
  squarePaymentId  String         @unique
  squareOrderId    String?
  status           PurchaseStatus @default(COMPLETED)
  creditsUsed      Decimal        @default(0) @db.Decimal(10, 2)
  creditsRemaining Decimal        @db.Decimal(10, 2)
  expiresAt        DateTime?
  purchasedAt      DateTime       @default(now())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  billingAccount   BillingAccount @relation(fields: [billingAccountId], references: [id])

  @@index([billingAccountId])
  @@index([status])
  @@map("credit_purchases")
}

model WhitelabelSubscription {
  id                   String                @id @default(uuid())
  billingAccountId     String                @unique
  planType             WhitelabelPlan        @default(BASIC)
  monthlyPrice         Decimal               @default(10.00) @db.Decimal(10, 2)
  status               SubscriptionStatus    @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  squareSubscriptionId String?               @unique
  squareCustomerId     String?
  billingDay           Int                   @default(1)
  lastBilledAt         DateTime?
  nextBillingAt        DateTime
  cancelledAt          DateTime?
  cancellationReason   String?
  endsAt               DateTime?
  trialStart           DateTime?
  trialEnd             DateTime?
  failedPaymentCount   Int                   @default(0)
  lastFailedAt         DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  payments             SubscriptionPayment[]
  billingAccount       BillingAccount        @relation(fields: [billingAccountId], references: [id])

  @@index([billingAccountId])
  @@index([status])
  @@index([nextBillingAt])
  @@map("whitelabel_subscriptions")
}

model SubscriptionPayment {
  id              String                 @id @default(uuid())
  subscriptionId  String
  amount          Decimal                @db.Decimal(10, 2)
  currency        String                 @default("USD")
  squarePaymentId String?                @unique
  squareInvoiceId String?
  status          PaymentStatus          @default(PENDING)
  periodStart     DateTime
  periodEnd       DateTime
  dueDate         DateTime
  paidAt          DateTime?
  failedAt        DateTime?
  failureReason   String?
  retryCount      Int                    @default(0)
  nextRetryAt     DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  subscription    WhitelabelSubscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
  @@map("subscription_payments")
}

model TaxRate {
  id            String    @id @default(uuid())
  state         String
  county        String?
  city          String?
  zipCode       String?
  stateTaxRate  Decimal   @db.Decimal(6, 4)
  localTaxRate  Decimal   @default(0) @db.Decimal(6, 4)
  combinedRate  Decimal   @db.Decimal(6, 4)
  effectiveDate DateTime  @default(now())
  expiresAt     DateTime?
  source        String?
  notes         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([state])
  @@index([state, city])
  @@index([zipCode])
  @@index([effectiveDate])
  @@map("tax_rates")
}

model TaxExemption {
  id                String           @id @default(uuid())
  eventId           String           @unique
  exemptionType     TaxExemptionType
  certificateNumber String?
  issuingAuthority  String?
  documentUrl       String?
  verificationNotes String?
  approved          Boolean          @default(false)
  approvedBy        String?
  approvedAt        DateTime?
  effectiveDate     DateTime         @default(now())
  expiresAt         DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  event             Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([exemptionType])
  @@index([approved])
  @@map("tax_exemptions")
}

model Affiliate {
  id               String                @id @default(uuid())
  userId           String                @unique
  businessName     String?
  taxId            String?
  w9Submitted      Boolean               @default(false)
  w9DocumentUrl    String?
  cashPinHash      String?
  pinLastChanged   DateTime?
  status           AffiliateStatus       @default(PENDING)
  approvedBy       String?
  approvedAt       DateTime?
  suspendedAt      DateTime?
  suspensionReason String?
  payoutMethod     PayoutMethod          @default(BANK_TRANSFER)
  bankAccountLast4 String?
  stripeConnectId  String?               @unique
  totalSales       Int                   @default(0)
  totalRevenue     Decimal               @default(0) @db.Decimal(12, 2)
  totalCommission  Decimal               @default(0) @db.Decimal(12, 2)
  totalPaidOut     Decimal               @default(0) @db.Decimal(12, 2)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  taxRecords       Affiliate1099Record[]
  affiliateLinks   AffiliateLink[]
  payouts          AffiliatePayout[]
  sales            AffiliateSale[]
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([stripeConnectId])
  @@map("affiliates")
}

model AffiliateLink {
  id              String          @id @default(uuid())
  affiliateId     String
  eventId         String
  linkCode        String          @unique
  trackingUrl     String          @unique
  commissionType  CommissionType  @default(PERCENTAGE)
  commissionValue Decimal         @db.Decimal(10, 2)
  clicks          Int             @default(0)
  conversions     Int             @default(0)
  totalSales      Decimal         @default(0) @db.Decimal(12, 2)
  isActive        Boolean         @default(true)
  expiresAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  affiliate       Affiliate       @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  event           Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sales           AffiliateSale[]

  @@index([affiliateId])
  @@index([eventId])
  @@index([linkCode])
  @@map("affiliate_links")
}

model AffiliateSale {
  id                String           @id @default(uuid())
  affiliateId       String
  affiliateLinkId   String?
  eventId           String
  orderId           String           @unique
  saleType          SaleType
  ticketCount       Int
  ticketPrice       Decimal          @db.Decimal(10, 2)
  subtotal          Decimal          @db.Decimal(10, 2)
  fees              Decimal          @default(0) @db.Decimal(10, 2)
  taxes             Decimal          @default(0) @db.Decimal(10, 2)
  total             Decimal          @db.Decimal(10, 2)
  commissionType    CommissionType
  commissionValue   Decimal          @db.Decimal(10, 2)
  commissionAmount  Decimal          @db.Decimal(10, 2)
  paymentMethod     PaymentMethod
  cashValidatedBy   String?
  cashPinValidated  Boolean          @default(false)
  cashValidatedAt   DateTime?
  wholesaleOwed     Decimal?         @db.Decimal(10, 2)
  settlementStatus  SettlementStatus @default(UNSETTLED)
  settledAt         DateTime?
  squarePaymentId   String?
  stripePaymentId   String?
  payoutId          String?
  saleDate          DateTime         @default(now())
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deviceFingerprint String?
  flaggedForReview  Boolean          @default(false)
  fraudFlags        String[]         @default([])
  fraudRiskScore    Int              @default(0)
  ipAddress         String?
  locationMatch     Boolean?
  reviewNotes       String?
  reviewedAt        DateTime?
  reviewedBy        String?
  soldByStaff       Boolean          @default(false)
  soldDuringEvent   Boolean          @default(false)
  affiliate         Affiliate        @relation(fields: [affiliateId], references: [id])
  affiliateLink     AffiliateLink?   @relation(fields: [affiliateLinkId], references: [id])
  event             Event            @relation(fields: [eventId], references: [id])
  order             Order            @relation(fields: [orderId], references: [id])
  payout            AffiliatePayout? @relation("SalePayout", fields: [payoutId], references: [id])

  @@index([affiliateId])
  @@index([eventId])
  @@index([orderId])
  @@index([settlementStatus])
  @@index([saleDate])
  @@index([soldDuringEvent, soldByStaff])
  @@index([flaggedForReview])
  @@index([fraudRiskScore])
  @@map("affiliate_sales")
}

model AffiliatePayout {
  id               String          @id @default(uuid())
  affiliateId      String
  payoutNumber     String          @unique
  amount           Decimal         @db.Decimal(10, 2)
  currency         String          @default("USD")
  periodStart      DateTime
  periodEnd        DateTime
  salesCount       Int
  totalCommission  Decimal         @db.Decimal(10, 2)
  platformFee      Decimal         @default(0) @db.Decimal(10, 2)
  netPayout        Decimal         @db.Decimal(10, 2)
  status           PayoutStatus    @default(PENDING)
  scheduledFor     DateTime
  processedAt      DateTime?
  payoutMethod     PayoutMethod
  stripeTransferId String?         @unique
  bankTransferId   String?
  failureReason    String?
  retryCount       Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  affiliate        Affiliate       @relation(fields: [affiliateId], references: [id])
  sales            AffiliateSale[] @relation("SalePayout")

  @@index([affiliateId])
  @@index([status])
  @@index([scheduledFor])
  @@map("affiliate_payouts")
}

model Affiliate1099Record {
  id                String    @id @default(uuid())
  affiliateId       String
  taxYear           Int
  totalEarnings     Decimal   @db.Decimal(12, 2)
  totalCommissions  Decimal   @db.Decimal(12, 2)
  totalPayouts      Decimal   @db.Decimal(12, 2)
  taxIdProvided     Boolean   @default(false)
  w9Submitted       Boolean   @default(false)
  form1099Required  Boolean
  form1099Generated Boolean   @default(false)
  form1099SentAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  affiliate         Affiliate @relation(fields: [affiliateId], references: [id])

  @@unique([affiliateId, taxYear])
  @@index([affiliateId])
  @@index([taxYear])
  @@map("affiliate_1099_records")
}

model EventToEventCategory {
  A                String
  B                String
  events           Event         @relation(fields: [A], references: [id], onDelete: Cascade)
  event_categories EventCategory @relation(fields: [B], references: [id], onDelete: Cascade)

  @@id([A, B], map: "_EventToEventCategory_AB_pkey")
  @@index([B], map: "_EventToEventCategory_B_index")
  @@map("_EventToEventCategory")
}

