// Platform Settings (Singleton pattern - only one row with id='1')
model PlatformSettings {
  id                  String   @id @default("1")
  platformName        String   @default("Stepperslife Events")
  platformDomain      String   @default("events.stepperslife.com")
  platformDescription String   @default("Your premier destination for discovering and hosting amazing events in the stepping community.")
  primaryColor        String   @default("#3b82f6")
  secondaryColor      String   @default("#06b6d4")
  logoUrl             String?
  faviconUrl          String?
  platformFeePercent  Decimal  @default(2.5) @db.Decimal(5, 2)
  emailFromName       String   @default("Stepperslife Events")
  emailFromAddress    String   @default("noreply@stepperslife.com")
  emailReplyTo        String?
  metadata            Json?    @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([id])
  @@map("platform_settings")
}

// Webhook Event Logging
model WebhookEvent {
  id              String                @id @default(uuid())
  source          String                // e.g., 'square', 'stripe'
  eventType       String                // e.g., 'payment.created'
  eventId         String?               // External event ID from webhook provider
  payload         Json                  // Full webhook payload
  signature       String?               // Webhook signature for verification
  status          WebhookEventStatus    @default(PENDING)
  processedAt     DateTime?
  errorMessage    String?
  retryCount      Int                   @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([source])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
  @@index([eventId])
  @@map("webhook_events")
}

enum WebhookEventStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  SKIPPED
}
