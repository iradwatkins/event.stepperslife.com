# Environment variables for Events Stepperslife
# Copy this file to .env and update with your actual values

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/events_stepperslife_db?schema=public"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3004"
NEXTAUTH_SECRET="your-nextauth-secret-here-change-this-in-production"

# Redis Cache
REDIS_URL="redis://localhost:6379"

# File Storage (MinIO)
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="events-stepperslife"

# App Configuration
NODE_ENV="development"
PORT="3004"

# Email (SendGrid)
SENDGRID_API_KEY="your-sendgrid-api-key"
SENDGRID_FROM_EMAIL="noreply@events.stepperslife.com"
SENDGRID_FROM_NAME="Stepperslife Events"

# Analytics
GOOGLE_ANALYTICS_ID="your-ga-id-here"

# OAuth Providers (for NextAuth)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Square Payment Configuration
# Production
SQUARE_APPLICATION_ID="your-square-application-id"
SQUARE_ACCESS_TOKEN="your-square-production-access-token"

# Sandbox (for development)
SQUARE_SANDBOX_APPLICATION_ID="your-square-sandbox-application-id"
SQUARE_SANDBOX_ACCESS_TOKEN="your-square-sandbox-access-token"

# Common Square Configuration
SQUARE_LOCATION_ID="your-square-location-id"
SQUARE_WEBHOOK_SIGNATURE_KEY="your-square-webhook-signature-key"
SQUARE_APP_FEE_PERCENTAGE="0" # Optional: Platform fee percentage

# Sentry Error Tracking (optional)
SENTRY_DSN="your-sentry-dsn"
SENTRY_ORG="your-sentry-organization"
SENTRY_PROJECT="your-sentry-project"

# Backup Configuration
BACKUP_DIR="/tmp/backups"
MAX_BACKUPS="7"
CRON_SECRET_TOKEN="your-cron-secret-token"

# S3 Backup Storage (optional)
BACKUP_S3_BUCKET="your-backup-bucket"
BACKUP_S3_ACCESS_KEY="your-s3-access-key"
BACKUP_S3_SECRET_KEY="your-s3-secret-key"
BACKUP_S3_REGION="us-east-1"
BACKUP_S3_ENDPOINT="https://s3.amazonaws.com" # Optional: for S3-compatible services